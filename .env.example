# Exchange API Keys (use withdrawal-disabled keys only)
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
COINBASE_API_KEY=
COINBASE_SECRET=

# Sentiment Data APIs
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=
GLASSNODE_API_KEY=

# Telegram Alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode: backtest | dry_run | live
TRADING_MODE=dry_run

# Risk Parameters
MAX_PORTFOLIO_PCT_PER_TRADE=0.05
CIRCUIT_BREAKER_24H_DRAWDOWN=0.10
CIRCUIT_BREAKER_7D_DRAWDOWN=0.20
MIN_SIGNAL_CONFIDENCE=0.65

# Freqtrade env var overrides (auto-injected into config at runtime)
# These override corresponding values in config.json without hardcoding secrets
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=
