# Exchange API Keys (use withdrawal-disabled keys only)
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=
COINBASE_API_KEY=
COINBASE_SECRET=

# Sentiment Data APIs
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=
GLASSNODE_API_KEY=

# Telegram Alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode: backtest | dry_run | live
TRADING_MODE=dry_run

# Risk Parameters
MAX_PORTFOLIO_PCT_PER_TRADE=0.05
CIRCUIT_BREAKER_24H_DRAWDOWN=0.10
CIRCUIT_BREAKER_7D_DRAWDOWN=0.20
MIN_SIGNAL_CONFIDENCE=0.55

# Pair Allocation Parameters
PAIR_ALLOC_WINDOW_DAYS=30
PAIR_ALLOC_MIN_TRADES=5
PAIR_ALLOC_EXPLORATION_PCT=0.10
PAIR_ALLOC_PF_THRESHOLD=0.7
PAIR_ALLOC_PF_CAP=5.0
PAIR_ALLOC_MIN_STAKE=10.0
PAIR_ALLOC_REFRESH_HOURS=4

# External Signal Sources (dormant by default — flip to true to activate)
FEAR_GREED_ENABLED=false
NEWS_SENTIMENT_ENABLED=false
CRYPTOPANIC_API_KEY=

# Freqtrade env var overrides (auto-injected into config at runtime)
# These override corresponding values in config.json without hardcoding secrets
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=
