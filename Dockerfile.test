FROM freqtradeorg/freqtrade:stable

USER root
RUN pip install xgboost lightgbm httpx datasieve pytest pytest-asyncio \
    && rm -rf /freqtrade/tests
USER ftuser

WORKDIR /freqtrade

COPY user_data/ /freqtrade/user_data/
COPY scripts/ /freqtrade/scripts/
COPY tests/ /freqtrade/tests/
COPY pyproject.toml /freqtrade/pyproject.toml

ENTRYPOINT []
CMD ["pytest", "tests/", "-v"]
